# Ollama Configuration
# The local URL where your Ollama server is running
OLLAMA_BASE_URL=http://127.0.0.1:11434

# The model name to use (e.g., llama3.2, neural-chat, mistral)
LLM_MODEL=llama3.2

# Web Search Provider
# Options: duckduckgo (free, default), tavily, brave, google, bing
WEB_SEARCH_PROVIDER=duckduckgo

# API Keys (only needed for non-default providers)
# TAVILY_API_KEY=your-tavily-api-key
# BRAVE_API_KEY=your-brave-api-key
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_CSE_ID=your-google-cse-id
# BING_API_KEY=your-bing-api-key

# Optional LLM Settings
# Temperature for deterministic output (0.0 = deterministic, best for extraction)
# LLM_TEMPERATURE=0.0

# Max tokens to generate per response (optional)
# LLM_MAX_TOKENS=2000
